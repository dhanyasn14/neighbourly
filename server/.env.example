MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development
FORCE_HTTPS=true
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=8h
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM_EMAIL=Neighborly <no-reply@example.com>
ALERT_FROM_EMAIL=Neighborly Alerts <alerts@example.com>
ADMIN_NOTIFY_EMAIL=admin1@example.com,admin2@example.com
RESET_OTP_SECRET=replace-with-a-different-long-random-secret
